rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verify Neural Node Admin Access
    function isArchitect() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper() == '👑 THE ARCHITECT' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.upper() == 'ARCHITECT'
      );
    }
    
    // Check if the current request is coming from a Master Identity
    function isMasterIdentity() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName.upper().matches('.*SIXKILLS.*');
    }

    // 1. User Profiles & Neural Networks
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isArchitect() || 
        isMasterIdentity() ||
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'coinsBalance', 'xp']))
      );
      allow delete: if isArchitect();

      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isArchitect());
      }
    }

    // 2. 30TB Neural Cloud Matrix (User Shredded Assets)
    match /user_assets/{pilotId} {
      allow read, write: if request.auth != null && (request.auth.uid == pilotId || isArchitect());
      
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && (request.auth.uid == pilotId || isArchitect());
      }
    }

    // 3. Legacy DNA Vault & Escrow Backups
    match /dna_vault/{docId} {
      allow read, write: if request.auth != null && (
        resource == null || 
        resource.data.artistId == request.auth.uid || 
        isArchitect()
      );
    }

    // 4. Global Audio Matrix & Config Definitions
    match /config/{configId} {
      allow read: if true;
      allow write: if isArchitect();
    }

    // 5. System Metadata (Traffic / Broadcast Stats)
    match /metadata/{documentId} {
      allow read: if true;
      allow update, create, write: if isArchitect() || (documentId == 'traffic' && request.auth != null);
    }

    // 6. Global Arena Feed (Human Track Battles)
    match /arena_tracks/{trackId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.artistId == request.auth.uid || isArchitect());
    }

    // Absolute Zero Trust Fallback for unauthorized shards
    match /{document=**} {
      allow read, write: if isArchitect();
    }
  }
}
